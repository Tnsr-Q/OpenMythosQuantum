# Safe placeholder file only. Do not commit real values.

APP_ENV=production
APP_PORT=8080
LOG_LEVEL=info

API_PUBLIC_BASE_URL=https://api.prod.katopu.example.com/v1
AUTH_ISSUER_URL=https://auth.katopu.example.com
AUTH_AUDIENCE=katopu-api

# Authentication
API_KEY_HEADER_NAME=X-API-Key
JWT_SIGNING_SECRET=replace_me
OAUTH_CLIENT_ID=replace_me
OAUTH_CLIENT_SECRET=replace_me

# Optional model provider
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1

# Storage
DATABASE_URL=postgresql://katopu:replace_me@db.internal:5432/katopu
REDIS_URL=redis://cache.internal:6379/0
OBJECT_STORAGE_ENDPOINT=https://s3.internal.example.com
OBJECT_STORAGE_BUCKET=katopu-artifacts
OBJECT_STORAGE_ACCESS_KEY=replace_me
OBJECT_STORAGE_SECRET_KEY=replace_me

# Notifications
SMTP_HOST=smtp.internal.example.com
SMTP_PORT=587
SMTP_USERNAME=replace_me
SMTP_PASSWORD=replace_me
NOTIFICATION_FROM=noreply@katopu.example.com
WEBHOOK_SIGNING_SECRET=replace_me

# Encryption
MASTER_ENCRYPTION_KEY=replace_me
ACTIVE_KEY_ID=key_2026_04

# TLS
TLS_CERT_PATH=/app/config/security/tls/server.crt
TLS_KEY_PATH=/app/config/security/tls/server.key
